/*-------------------------------------------
--Fullscreen image edit multiple
-------------------------------------------*/

/**rgb(168, 199, 250)**/

aside#fullscreen_edit {
	color: #333;
	top: 0px;
	left: 0px;
	width: 100%;
	height: 100vh;
	display: none;
	justify-content: center;
	align-items: center;
	overflow: hidden;
	position: sticky;
	background-color: color(srgb 1 1 1 / 0.90);
	box-sizing: border-box;
    padding: 20px 50px 20px 50px;
	border-top: 140px solid #a8c7fa;
	border-bottom: 140px solid #a8c7fa;
}

aside#fullscreen_edit.fullscreen
{
	display: grid;
	grid-template-columns: 450px max-content;
	justify-content: start;
}

div#filelist
{
	display: grid;
	grid-template-columns: auto auto;	
	justify-content: start;	
	grid-column-gap: 30px;
	grid-row-gap: 5px;
}

aside#fullscreen_edit div.infocontent
{
	background-color: transparent !important;
	height: 100% !important;
	scrollbar-width: none;       /* Firefox */
	-ms-overflow-style: none;    /* IE / Edge legacy */
}

aside#fullscreen_edit h3.conflict span:not(.hover-show):not(.hover-hide)
{
	color: darkorange;
}

aside#fullscreen_edit h3 button
{
	display: none;
	width: 300px;
	background-color: white;
}

aside#fullscreen_edit h4 button.cancel, 
aside#fullscreen_edit h3 span.cursor,
aside#fullscreen_edit h3 button span.hover-show,
aside#fullscreen_edit h3 button:hover span.hover-hide
{
	display: none;
}

aside#fullscreen_edit h3 button:hover span.hover-show
{
	display: inline-block;
}

aside#fullscreen_edit h3 button span.hover-show,
aside#fullscreen_edit h3 button span.hover-hide
{
	margin-left: 0px !important;
}

aside#fullscreen_edit h3 button
{
	text-align: left !important;
}

aside#fullscreen_edit #filelist div.fake-link {
  /* Couleur et décoration comme un lien */
  color: #0066cc; /* Bleu classique des liens */
  text-decoration: underline;
  cursor: pointer; /* Curseur "main" au survol */

  /* Comportement au survol (hover) */
  transition: color 0.2s ease;
}

aside#fullscreen_edit #filelist div.fake-link:hover {
  color: #004499; /* Bleu plus foncé au survol */
  text-decoration: underline;
}

aside#fullscreen_edit #conflict-quicklook
{
	display: none;
	height: 100%;
}


aside#fullscreen_edit #conflict-quicklook img
{
	width: 100%;
    height: 100%;
    object-fit: contain;
}

aside#fullscreen_edit #filelist
{
	margin-left: 35px;
}

aside#fullscreen_edit #trash-info span.material-symbols-outlined,
aside#fullscreen_edit #conflict-info span.material-symbols-outlined,
div#select-status span.delete
{
	color: red;
}

aside#fullscreen_edit h3#conflict-info
{
	margin-top: 10px;
	margin-bottom: 10px;
}

aside#fullscreen_edit h4 button.save
{
	margin-left: 93px !important;
}

aside#fullscreen_edit div#blockreturnfilesinfo div.return
{
    margin-left: 93px;
    margin-right: 35px;
}

aside#fullscreen_edit form.hidden
{
	display: none;
}